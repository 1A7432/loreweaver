# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Auto-generated by setuptools-scm (tool.setuptools_scm.version_file) — git-derived,
# never hand-edited or committed.
/_lw_version.py
# Baked by loreweaver-server.spec at PyInstaller build time (frozen --version sidecar).
/VERSION

# Launch/press kit + personal career notes — private drafts, never published via git.
promo/

# --- Secrets & runtime data (NEVER commit) ---
.env
.env.*
!.env.example
# databases + runtime state
*.db
*.sqlite
*.sqlite3
data/
shared/
# issued keys / host keys (only the *.example.* files are committed)
**/keys.toml
**/tui_keys.toml
**/ssh_keys.toml
*_host_key
*_host_key.pub
*.pem
!**/*.example.toml

# --- Node / clients ---
node_modules/
clients/*/dist/
*.tsbuildinfo
.vite/
coverage/
.bun/

# --- Internal (not published: design specs + build blueprint) ---
docs/specs/
PROMPT.md

# --- Local play-test material (user-supplied modules / cards; may be copyrighted) ---
modules/
playtest/
cards/

# --- Misc ---
.DS_Store
*.log
scratch/

# TUI preview render artifact
clients/tui/preview_frame.txt

# local-only play launcher that loads private module/card material (not for the public repo)
scripts/play_tui.sh
.prompts/
