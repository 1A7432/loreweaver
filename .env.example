# --- LLM (OpenAI-compatible; DeepSeek etc. supported) ---
TRPG_LLM__API_KEY=sk-...
TRPG_LLM__BASE_URL=https://api.openai.com/v1
TRPG_LLM__CHAT_MODEL=gpt-4o
TRPG_LLM__EMBEDDING_MODEL=text-embedding-3-small
TRPG_LLM__EMBEDDING_DIM=1536

# --- Runtime ---
TRPG_LOCALE=en
TRPG_DATA_DIR=./data
TRPG_ENABLE_VECTOR_DB=true

# --- Platform adapters (fill only what you deploy) ---
# TRPG_QQ__APP_ID=
# TRPG_QQ__SECRET=
# TRPG_TELEGRAM__TOKEN=
# TRPG_DISCORD__TOKEN=
# TRPG_DISCORD__APP_ID=
# TRPG_FEISHU__APP_ID=
# TRPG_FEISHU__APP_SECRET=
