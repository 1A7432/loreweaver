# --- LLM (OpenAI-compatible + native anthropic/gemini) ---
# PROVIDER picks a base_url preset (openai/deepseek/groq/openrouter/together/ollama/lmstudio/...
# or anthropic/gemini). `chatgpt` / `gpt-subscription` are dual-mode: leave
# BASE_URL blank after `.model login chatgpt` for subscription OAuth, or set it
# to an OpenAI-compatible gateway for the classic proxy + API-key path.
# `supergrok` always uses the grant obtained by `.model login supergrok`.
TRPG_LLM__PROVIDER=deepseek
TRPG_LLM__API_KEY=sk-...
# TRPG_LLM__BASE_URL=https://proxy.example/v1
# A capable Keeper matters: strong models run the module's own scenes and roll dice via the
# tools; budget models (e.g. a *-flash tier) drift off-module and narrate without rolling.
TRPG_LLM__CHAT_MODEL=deepseek-v4-pro
# DeepSeek thinking mode: "high" (default depth) or "max" (hardest reasoning). Blank = off /
# non-reasoning model. Do NOT set a temperature alongside it — thinking mode ignores temperature
# and a low value degrades the reasoning trace; omit it entirely and the provider uses its default.
TRPG_LLM__REASONING_EFFORT=max
TRPG_LLM__EMBEDDING_MODEL=text-embedding-3-small
TRPG_LLM__EMBEDDING_DIM=1536
# (Chat-only providers with no embeddings endpoint fall back to a local hash embedder automatically.)
# PRIVACY BOUNDARY: a remote LLM receives module text, keeper-only lore, relevant history, and
# current player input. The standard app uses local hash embeddings; an explicitly wired remote
# embedding backend would also receive document chunks. Use a local Ollama/LM Studio endpoint when
# prompts must stay on infrastructure you control. Runtime credentials are persisted unencrypted
# in local SQLite; see docs/deploy.md "Data flow and trust boundaries".

# --- Runtime ---
TRPG_LOCALE=en
TRPG_DATA_DIR=./data
TRPG_ENABLE_VECTOR_DB=true

# --- Iroh session / media limits (`python -m app --serve`) ---
# Seconds an unauthenticated connection has to send its `join` frame before the server closes
# it (blocks connection-exhaustion from peers that open a socket and never authenticate).
TRPG_TUI__JOIN_TIMEOUT=10

# --- Content moderation (gateway/ops.py Censor) ---
# OFF by default: Loreweaver ships NO built-in wordlist. Set ONE of these to turn it on. It
# currently only screens the AI Keeper's OWN narration (not player input) -- see docs/deploy.md
# "Content moderation" before relying on this for anything beyond a light guardrail.
# TRPG_CENSOR__WORDLIST_PATH=/path/to/wordlist.json   # {"word": level, ...}; level 1-5, see CensorLevel
# TRPG_CENSOR__WORDLIST=slur1:5,slur2:4                # inline word[:level],word2[:level2],... (no file needed)

# --- Platform adapters (fill only what you deploy) ---
# TRPG_QQ__APP_ID=
# TRPG_QQ__SECRET=
# Custom Markdown template; it must define a parameter named `content`.
# TRPG_QQ__MARKDOWN_TEMPLATE_ID=
# Optional static Keyboard template; this does not enable dynamic control buttons.
# TRPG_QQ__KEYBOARD_ID=
# Dynamic buttons also require MARKDOWN_TEMPLATE_ID.
# TRPG_QQ__KEYBOARD_ENABLED=false
# TRPG_TELEGRAM__TOKEN=
# TRPG_DISCORD__TOKEN=
# 0 syncs commands globally; use a guild ID for immediate development-server sync.
# TRPG_DISCORD__GUILD_ID=0
# TRPG_DISCORD__FFMPEG=ffmpeg
# TRPG_FEISHU__APP_ID=
# TRPG_FEISHU__APP_SECRET=
